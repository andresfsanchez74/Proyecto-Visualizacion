{
  "$schema": "https://developer.microsoft.com/json-schemas/fabric/item/report/definition/visualContainer/2.9.0/schema.json",
  "name": "chart_os_donut",
  "position": {
    "x": 430,
    "y": 435,
    "z": 5000,
    "height": 275,
    "width": 400,
    "tabOrder": 5000
  },
  "visual": {
    "visualType": "donutChart",
    "query": {
      "queryState": {
        "Category": {
          "projections": [
            {
              "field": {
                "Column": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "dim_OS"
                    }
                  },
                  "Property": "OS"
                }
              },
              "queryRef": "dim_OS.OS",
              "active": true,
              "displayName": "Sistema Operativo"
            }
          ]
        },
        "Y": {
          "projections": [
            {
              "field": {
                "Measure": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "survey_2025_results"
                    }
                  },
                  "Property": "Total Respondents"
                }
              },
              "queryRef": "survey_2025_results.Total Respondents"
            }
          ]
        }
      }
    },
    "objects": {
      "legend": [
        {
          "properties": {
            "show": {
              "expr": {
                "Literal": {
                  "Value": "true"
                }
              }
            },
            "position": {
              "expr": {
                "Literal": {
                  "Value": "'Right'"
                }
              }
            }
          }
        }
      ]
    },
    "drillFilterOtherVisuals": true
  }
}