	column ExperienceRange = SWITCH(TRUE(), ISBLANK(survey_2025_results[YearsCode]), "Unknown", survey_2025_results[YearsCode] <= 2, "0-2 Junior", survey_2025_results[YearsCode] <= 5, "3-5 Mid", survey_2025_results[YearsCode] <= 10, "6-10 Senior", survey_2025_results[YearsCode] <= 20, "11-20 Staff", "20+ Principal")
		dataType: string
